{
  "name": "{{ env_name }}",
  "base_url": "{{ env_base_url | default(base_url ~ '/' ~ env_name) }}",
  "variables": {},
  {% if auth_type != "none" %}
  "auth": {
    "type": "{{ auth_type }}",
    {% if auth_type == "bearer" %}
    "token_env": "{{ project_name | upper }}_{{ env_name | upper }}_TOKEN"
    {% elif auth_type == "basic" %}
    "username_env": "{{ project_name | upper }}_{{ env_name | upper }}_USERNAME",
    "password_env": "{{ project_name | upper }}_{{ env_name | upper }}_PASSWORD"
    {% elif auth_type == "api_key" %}
    "key_env": "{{ project_name | upper }}_{{ env_name | upper }}_API_KEY",
    "header_name": "X-API-Key"
    {% elif auth_type == "oauth2" %}
    "token_env": "{{ project_name | upper }}_{{ env_name | upper }}_OAUTH_TOKEN",
    "client_id_env": "{{ project_name | upper }}_{{ env_name | upper }}_CLIENT_ID",
    "client_secret_env": "{{ project_name | upper }}_{{ env_name | upper }}_CLIENT_SECRET"
    {% endif %}
  }
  {% endif %}
}